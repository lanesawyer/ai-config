#!/usr/bin/env bash
# setup — bootstrap ai-config on a new machine (macOS or Linux)
#
# Usage: bash ~/dev/ai-config/setup
#   or:  ~/dev/ai-config/setup
#
# Idempotent — safe to run multiple times.

set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
INIT_FILE="$REPO_DIR/shell/init.zsh"
SOURCE_LINE="source $INIT_FILE"

echo "ai-config setup"
echo "  repo: $REPO_DIR"
echo ""

# ---------- make sure scripts are executable ----------
echo "→ Ensuring scripts are executable..."
chmod +x "$REPO_DIR"/skills/create-worktree/scripts/*
chmod +x "$REPO_DIR"/skills/remove-worktree/scripts/*
echo "  done"

# ---------- wire up shell(s) ----------
wire_shell() {
    local rc_file="$1"
    local shell_name="$2"

    [[ -f "$rc_file" ]] || return 0  # skip if rc file doesn't exist

    if grep -qF "$SOURCE_LINE" "$rc_file" 2>/dev/null; then
        echo "  $shell_name: already wired ($rc_file)"
    else
        echo "" >> "$rc_file"
        echo "# ai-config tools (worktree scripts, etc.)" >> "$rc_file"
        echo "$SOURCE_LINE" >> "$rc_file"
        echo "  $shell_name: added source line to $rc_file"
    fi
}

echo "→ Wiring shell config..."
wire_shell "$HOME/.zshrc"  "zsh"
wire_shell "$HOME/.bashrc" "bash"

# macOS Terminal.app / older macOS uses .bash_profile instead of .bashrc for login shells
if [[ "$(uname)" == "Darwin" ]] && [[ -f "$HOME/.bash_profile" ]] && ! grep -qF "$SOURCE_LINE" "$HOME/.bash_profile" 2>/dev/null; then
    # Only add to .bash_profile if .bashrc doesn't exist (avoid double-sourcing)
    if [[ ! -f "$HOME/.bashrc" ]]; then
        wire_shell "$HOME/.bash_profile" "bash (login)"
    fi
fi

# ---------- link AI skills ----------
link_skill() {
    local skill_src="$1"
    local target_dir="$2"
    local skill_name
    skill_name="$(basename "$skill_src")"
    local target="$target_dir/$skill_name"

    if [[ -L "$target" ]]; then
        echo "  $skill_name: already linked"
    elif [[ -e "$target" ]]; then
        echo "  WARNING: $target exists and is not a symlink — skipping $skill_name"
        echo "           Remove it manually to let setup link the repo version."
    else
        ln -s "$skill_src" "$target"
        echo "  $skill_name: linked"
    fi
}

echo "→ Linking AI skills..."

SKILLS_DIR="$REPO_DIR/skills"

if [[ -d "$SKILLS_DIR" ]]; then
    # ~/.claude/skills/ is scanned by both Claude Code and GitHub Copilot.
    # ~/.agents/skills/ is also scanned by Copilot, so linking to both causes
    # duplicate slash commands — link only to ~/.claude/skills/.
    CLAUDE_SKILLS="$HOME/.claude/skills"
    mkdir -p "$CLAUDE_SKILLS"
    echo "  ~/.claude/skills/ (used by Claude Code and GitHub Copilot):"
    for skill_src in "$SKILLS_DIR"/*/; do
        [[ -d "$skill_src" ]] || continue
        link_skill "$skill_src" "$CLAUDE_SKILLS"
    done
else
    echo "  no skills/ directory found — skipping"
fi

# ---------- link Zed tasks ----------
echo ""
echo "→ Linking Zed tasks..."
ZED_CONFIG_DIR="$HOME/.config/zed"
ZED_TASKS_FILE="$ZED_CONFIG_DIR/tasks.json"
mkdir -p "$ZED_CONFIG_DIR"

if [[ -L "$ZED_TASKS_FILE" ]]; then
    echo "  tasks.json: already linked"
elif [[ -e "$ZED_TASKS_FILE" ]]; then
    echo "  WARNING: $ZED_TASKS_FILE exists and is not a symlink — skipping"
    echo "           Remove it manually to let setup link the repo version."
else
    ln -s "$REPO_DIR/zed/tasks.json" "$ZED_TASKS_FILE"
    echo "  tasks.json: linked"
fi

# ---------- done ----------
echo ""
echo "✓ Setup complete. Reload your shell:"
echo ""
echo "   source ~/.zshrc    (zsh)"
echo "   source ~/.bashrc   (bash)"
echo ""
echo "Then try:"
echo "   cd ~/dev/some-repo && git worktree-new lane/my-branch"
