#!/usr/bin/env bash
# setup — bootstrap ai-config on a new machine (macOS or Linux)
#
# Usage: bash ~/dev/ai-config/setup
#   or:  ~/dev/ai-config/setup
#
# Idempotent — safe to run multiple times.

set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "ai-config setup"
echo "  repo: $REPO_DIR"
echo ""

# ---------- make sure scripts are executable ----------
echo "→ Ensuring scripts are executable..."
chmod +x "$REPO_DIR"/skills/create-worktree/scripts/*
chmod +x "$REPO_DIR"/skills/remove-worktree/scripts/*
echo "  done"

# ---------- link AI skills ----------
link_skill() {
    local skill_src="$1"
    local target_dir="$2"
    local skill_name
    skill_name="$(basename "$skill_src")"
    local target="$target_dir/$skill_name"

    if [[ -L "$target" ]]; then
        echo "  $skill_name: already linked"
    elif [[ -e "$target" ]]; then
        echo "  WARNING: $target exists and is not a symlink — skipping $skill_name"
        echo "           Remove it manually to let setup link the repo version."
    else
        ln -s "$skill_src" "$target"
        echo "  $skill_name: linked"
    fi
}

echo "→ Linking AI skills..."

SKILLS_DIR="$REPO_DIR/skills"

if [[ -d "$SKILLS_DIR" ]]; then
    CLAUDE_SKILLS="$HOME/.claude/skills"
    mkdir -p "$CLAUDE_SKILLS"
    echo "  ~/.claude/skills/ (Claude Code):"
    for skill_src in "$SKILLS_DIR"/*/; do
        [[ -d "$skill_src" ]] || continue
        link_skill "$skill_src" "$CLAUDE_SKILLS"
    done

    AGENTS_SKILLS="$HOME/.agents/skills"
    mkdir -p "$AGENTS_SKILLS"
    echo "  ~/.agents/skills/:"
    for skill_src in "$SKILLS_DIR"/*/; do
        [[ -d "$skill_src" ]] || continue
        link_skill "$skill_src" "$AGENTS_SKILLS"
    done
else
    echo "  no skills/ directory found — skipping"
fi

# ---------- link Zed config ----------
echo ""
echo "→ Linking Zed config..."
ZED_CONFIG_DIR="$HOME/.config/zed"
mkdir -p "$ZED_CONFIG_DIR"

ZED_TASKS_FILE="$ZED_CONFIG_DIR/tasks.json"
if [[ -L "$ZED_TASKS_FILE" ]]; then
    echo "  tasks.json: already linked"
elif [[ -e "$ZED_TASKS_FILE" ]]; then
    echo "  WARNING: $ZED_TASKS_FILE exists and is not a symlink — skipping"
    echo "           Remove it manually to let setup link the repo version."
else
    ln -s "$REPO_DIR/zed/tasks.json" "$ZED_TASKS_FILE"
    echo "  tasks.json: linked"
fi

ZED_COPY_ENV="$ZED_CONFIG_DIR/copy-env.sh"
if [[ -L "$ZED_COPY_ENV" ]]; then
    echo "  copy-env.sh: already linked"
elif [[ -e "$ZED_COPY_ENV" ]]; then
    echo "  WARNING: $ZED_COPY_ENV exists and is not a symlink — skipping"
    echo "           Remove it manually to let setup link the repo version."
else
    ln -s "$REPO_DIR/zed/copy-env.sh" "$ZED_COPY_ENV"
    echo "  copy-env.sh: linked"
fi

ZED_INSTALL_JS="$ZED_CONFIG_DIR/install-js-deps.sh"
if [[ -L "$ZED_INSTALL_JS" ]]; then
    echo "  install-js-deps.sh: already linked"
elif [[ -e "$ZED_INSTALL_JS" ]]; then
    echo "  WARNING: $ZED_INSTALL_JS exists and is not a symlink — skipping"
    echo "           Remove it manually to let setup link the repo version."
else
    ln -s "$REPO_DIR/zed/install-js-deps.sh" "$ZED_INSTALL_JS"
    echo "  install-js-deps.sh: linked"
fi

ZED_AGENTS_FILE="$ZED_CONFIG_DIR/AGENTS.md"
if [[ -L "$ZED_AGENTS_FILE" ]]; then
    echo "  AGENTS.md: already linked"
elif [[ -e "$ZED_AGENTS_FILE" ]]; then
    echo "  WARNING: $ZED_AGENTS_FILE exists and is not a symlink — skipping"
    echo "           Remove it manually to let setup link the repo version."
else
    ln -s "$REPO_DIR/AGENTS.md" "$ZED_AGENTS_FILE"
    echo "  AGENTS.md: linked"
fi

# ---------- link Claude user-level instructions ----------
echo ""
echo "→ Linking Claude user config..."
CLAUDE_CONFIG_DIR="$HOME/.claude"
mkdir -p "$CLAUDE_CONFIG_DIR"

CLAUDE_MD_FILE="$CLAUDE_CONFIG_DIR/CLAUDE.md"
if [[ -L "$CLAUDE_MD_FILE" ]]; then
    echo "  CLAUDE.md: already linked"
elif [[ -e "$CLAUDE_MD_FILE" ]]; then
    echo "  WARNING: $CLAUDE_MD_FILE exists and is not a symlink — skipping"
    echo "           Remove it manually to let setup link the repo version."
else
    ln -s "$REPO_DIR/AGENTS.md" "$CLAUDE_MD_FILE"
    echo "  CLAUDE.md: linked"
fi

# ---------- done ----------
echo ""
echo "✓ Setup complete."
