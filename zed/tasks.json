// User-level Zed tasks. See https://zed.dev/docs/tasks for documentation.
//
// Managed by ai-config — symlinked from ~/.config/zed/tasks.json by `setup`.
[
  {
    "label": "copy .env into new worktree",
    "command": "sh",
    "args": [
      "-c",
      "[ -f \"$ZED_MAIN_GIT_WORKTREE/.env\" ] && cp \"$ZED_MAIN_GIT_WORKTREE/.env\" \"$ZED_WORKTREE_ROOT/.env\" && echo \"copied .env\" || echo \"no .env in main worktree — skipping\""
    ],
    "hooks": ["create_worktree"],
    "reveal": "no_focus",
    "hide": "on_success",
  },
  {
    "label": "install JS deps",
    "command": "sh",
    "args": [
      "-c",
      "cd \"$ZED_WORKTREE_ROOT\" && if [ -f pnpm-lock.yaml ]; then pnpm install; elif [ -f package-lock.json ]; then npm install; else echo \"no JS lockfile — skipping\"; fi"
    ],
    "hooks": ["create_worktree"],
    "reveal": "no_focus",
    "hide": "on_success",
  },
]
